generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Motion {
  id                String    @id @default(cuid())
  tier              String    // "priority" | "tier2" | "passed"
  program           String
  dateReceived      DateTime?
  councilFile       String?   @unique
  expiration        DateTime?
  status            String?
  reportBackDue     DateTime?
  statusDate        DateTime?
  originalMotionUrl String?
  motionMaker       String?

  // Scraped fields
  scrapedTitle       String?
  scrapedLastChanged DateTime?
  scrapedMover       String?
  scrapedSecond      String?
  lastScrapedAt      DateTime?

  activities    Activity[]
  subscriptions Subscription[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id       String   @id @default(cuid())
  motionId String
  motion   Motion   @relation(fields: [motionId], references: [id], onDelete: Cascade)
  date     DateTime
  activity String

  createdAt DateTime @default(now())
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "motion" | "all"
  motionId  String?
  motion    Motion?  @relation(fields: [motionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  notifications Notification[]

  @@unique([userId, type, motionId])
}

model Notification {
  id             String       @id @default(cuid())
  userId         String
  motionId       String
  motion         Motion       @relation(fields: [motionId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  message        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
}
